---
interface RecommendationItem {
  id: string;
  title: string;
  subtitle: string;
  workPrimary: string;
  workSecondary: string;
  principalPrimary: string;
  principalSecondary: string;
  supportingPrimary: string;
  supportingSecondary: string;
  ensemblePrimary: string;
  ensembleSecondary: string;
  datePlacePrimary: string;
  datePlaceSecondary: string;
  href: string;
  imageSrc: string;
}

interface Props {
  items: RecommendationItem[];
}

const { items } = Astro.props;
const initialItems = items.slice(0, 5);

const renderSlot = (primary?: string, secondary?: string, className = "") =>
  primary || secondary
    ? `<div class="daily-card__slot ${className}">
        ${primary ? `<p class="daily-card__slot-primary">${primary}</p>` : ""}
        ${secondary ? `<p class="daily-card__slot-secondary">${secondary}</p>` : ""}
      </div>`
    : "";
---

<section class="daily-section">
  <div class="section-heading section-heading--centered">
    <p class="section-heading__eyebrow">Daily Rotation</p>
    <h2>每日推荐</h2>
  </div>

  <div class="daily-strip" data-daily-strip>
    {initialItems.map((item) => (
      <article class="daily-card">
        <a class="daily-card__link" href={item.href}>
          {item.imageSrc ? (
            <img class="daily-card__image" src={item.imageSrc} alt={item.title} loading="lazy" />
          ) : (
            <div class="daily-card__image daily-card__image--empty">{item.title}</div>
          )}
          <div class="daily-card__body">
            <h3 class="daily-card__title">{item.title}</h3>
            <p class="daily-card__subtitle">{item.subtitle}</p>
            {item.workPrimary && <p class="daily-card__work">{item.workPrimary}</p>}
            {item.workSecondary && <p class="daily-card__work daily-card__work--secondary">{item.workSecondary}</p>}
            <div class="daily-card__slots">
              <Fragment set:html={renderSlot(item.principalPrimary, item.principalSecondary, "daily-card__slot--principal")} />
              <Fragment set:html={renderSlot(item.supportingPrimary, item.supportingSecondary, "daily-card__slot--supporting")} />
              <Fragment set:html={renderSlot(item.ensemblePrimary, item.ensembleSecondary, "daily-card__slot--ensemble")} />
              <Fragment set:html={renderSlot(item.datePlacePrimary, item.datePlaceSecondary, "daily-card__slot--date")} />
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<script is:inline define:vars={{ items }}>
  const strip = document.querySelector("[data-daily-strip]");

  const hashValue = (value) => {
    let hash = 2166136261;
    for (let index = 0; index < value.length; index += 1) {
      hash ^= value.charCodeAt(index);
      hash = Math.imul(hash, 16777619);
    }
    return hash >>> 0;
  };

  const pickDaily = (allItems, dateKey, count) =>
    [...allItems]
      .sort((left, right) => hashValue(`${dateKey}:${left.id}`) - hashValue(`${dateKey}:${right.id}`))
      .slice(0, Math.min(count, allItems.length));

  const escapeHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const renderSlotHtml = (primary, secondary, className = "") =>
    primary || secondary
      ? `<div class="daily-card__slot ${className}">
          ${primary ? `<p class="daily-card__slot-primary">${primary}</p>` : ""}
          ${secondary ? `<p class="daily-card__slot-secondary">${secondary}</p>` : ""}
        </div>`
      : "";

  const render = (records) => {
    if (!strip) {
      return;
    }

    strip.innerHTML = records
      .map((item) => {
        const image = item.imageSrc
          ? `<img class="daily-card__image" src="${escapeHtml(item.imageSrc)}" alt="${escapeHtml(item.title)}" loading="lazy" />`
          : `<div class="daily-card__image daily-card__image--empty">${escapeHtml(item.title)}</div>`;

        return `
          <article class="daily-card">
            <a class="daily-card__link" href="${escapeHtml(item.href)}">
              ${image}
              <div class="daily-card__body">
                <h3 class="daily-card__title">${escapeHtml(item.title)}</h3>
                <p class="daily-card__subtitle">${escapeHtml(item.subtitle || "")}</p>
                ${item.workPrimary ? `<p class="daily-card__work">${escapeHtml(item.workPrimary)}</p>` : ""}
                ${item.workSecondary ? `<p class="daily-card__work daily-card__work--secondary">${escapeHtml(item.workSecondary)}</p>` : ""}
                <div class="daily-card__slots">
                  ${renderSlotHtml(escapeHtml(item.principalPrimary || ""), escapeHtml(item.principalSecondary || ""), "daily-card__slot--principal")}
                  ${renderSlotHtml(escapeHtml(item.supportingPrimary || ""), escapeHtml(item.supportingSecondary || ""), "daily-card__slot--supporting")}
                  ${renderSlotHtml(escapeHtml(item.ensemblePrimary || ""), escapeHtml(item.ensembleSecondary || ""), "daily-card__slot--ensemble")}
                  ${renderSlotHtml(escapeHtml(item.datePlacePrimary || ""), escapeHtml(item.datePlaceSecondary || ""), "daily-card__slot--date")}
                </div>
              </div>
            </a>
          </article>
        `;
      })
      .join("");
  };

  const dateKey = new Date().toISOString().slice(0, 10);
  render(pickDaily(items, dateKey, 5));
</script>
