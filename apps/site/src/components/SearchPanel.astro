---
interface SearchEntry {
  id: string;
  kind: "composer" | "workGroup" | "work" | "conductor" | "orchestra" | "person";
  primaryText: string;
  secondaryText: string;
  href: string;
  matchTokens: string[];
  aliasTokens: string[];
}

interface Props {
  items: SearchEntry[];
}

const { items } = Astro.props;
---

<section class="search-panel" data-search-panel>
  <div class="section-heading">
    <p class="section-heading__eyebrow">Search</p>
    <h1>搜索索引</h1>
    <p class="page-lead">搜索结果按类型分组展示，每类仅保留前 5 个示例，优先返回目录实体而不是版本列表。</p>
  </div>

  <div class="search-panel__controls">
    <label class="sr-only" for="search-page-input">搜索</label>
    <input id="search-page-input" data-search-input type="search" name="q" placeholder="输入作曲家、指挥、乐团、作品类型或作品名" />
  </div>

  <div class="search-panel__results" data-search-results></div>
</section>

<script is:inline define:vars={{ items }}>
  const container = document.querySelector("[data-search-panel]");
  const input = container?.querySelector("[data-search-input]");
  const results = container?.querySelector("[data-search-results]");
  const params = new URLSearchParams(window.location.search);

  const labels = {
    composer: "作曲家",
    conductor: "指挥",
    orchestra: "乐团",
    workGroup: "类型",
    work: "作品",
    person: "人物",
  };

  const order = ["composer", "conductor", "orchestra", "workGroup", "work", "person"];

  const escapeHtml = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const normalize = (value) =>
    String(value ?? "")
      .normalize("NFKC")
      .toLowerCase()
      .replace(/[·・•.。,'"`“”‘’()（）[\]\\/_-]+/g, " ")
      .replace(/\s+/g, " ")
      .trim();

  const groupEntries = (entries) => {
    const groups = new Map();

    entries.forEach((entry) => {
      const bucket = groups.get(entry.kind) ?? [];
      bucket.push(entry);
      groups.set(entry.kind, bucket);
    });

    return order.filter((kind) => groups.has(kind)).map((kind) => [kind, groups.get(kind)]);
  };

  const matches = (entry, normalizedQuery) => {
    if (!normalizedQuery) {
      return true;
    }

    const queryTokens = normalizedQuery.split(" ").filter(Boolean);
    const pool = [...(entry.matchTokens ?? []), ...(entry.aliasTokens ?? []), entry.primaryText, entry.secondaryText]
      .map(normalize)
      .filter(Boolean);

    return queryTokens.every((queryToken) => pool.some((token) => token.includes(queryToken)));
  };

  const render = (query) => {
    if (!results) {
      return;
    }

    const normalizedQuery = normalize(query);
    const matched = !normalizedQuery ? items.slice(0, 24) : items.filter((entry) => matches(entry, normalizedQuery));

    if (matched.length === 0) {
      results.innerHTML = `<p class="page-note">没有找到匹配项。</p>`;
      return;
    }

    const grouped = groupEntries(matched);
    results.innerHTML = grouped
      .map(([kind, entries]) => {
        const rows = entries
          .slice(0, 5)
          .map(
            (entry) => `
              <li class="search-result">
                <a href="${escapeHtml(entry.href)}">
                  <strong>${escapeHtml(entry.primaryText)}</strong>
                  <span>${escapeHtml(entry.secondaryText ?? "")}</span>
                </a>
              </li>
            `,
          )
          .join("");
        return `
          <section class="search-group">
            <div class="search-group__header">
              <h2>${labels[kind]}</h2>
              <span>${Math.min(entries.length, 5)} / ${entries.length}</span>
            </div>
            <ul>${rows}</ul>
          </section>
        `;
      })
      .join("");
  };

  if (input instanceof HTMLInputElement) {
    const initialValue = params.get("q") ?? "";
    input.value = initialValue;
    render(initialValue);

    input.addEventListener("input", (event) => {
      const value = event.currentTarget instanceof HTMLInputElement ? event.currentTarget.value : "";
      const nextUrl = new URL(window.location.href);
      if (value.trim()) {
        nextUrl.searchParams.set("q", value);
      } else {
        nextUrl.searchParams.delete("q");
      }
      window.history.replaceState({}, "", nextUrl);
      render(value);
    });
  }
</script>
