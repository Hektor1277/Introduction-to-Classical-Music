---
import DailyRecommendations from "@/components/DailyRecommendations.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildRecordingDisplayModel } from "@/lib/display";
import { readGeneratedLibrary, readGeneratedSite } from "@/lib/library-store";
import { buildRecentWorkUpdates } from "@/lib/site-content";

const [site, library] = await Promise.all([readGeneratedSite(), readGeneratedLibrary()]);

const recommendationItems = library.recordings.map((recording) => {
  const display = buildRecordingDisplayModel(recording, library);

  return {
    id: recording.id,
    title: display.title,
    subtitle: display.subtitle,
    workPrimary: display.daily.workPrimary,
    workSecondary: display.daily.workSecondary,
    principalPrimary: display.daily.principalPrimary,
    principalSecondary: display.daily.principalSecondary,
    supportingPrimary: display.daily.supportingPrimary,
    supportingSecondary: display.daily.supportingSecondary,
    ensemblePrimary: display.daily.ensemblePrimary,
    ensembleSecondary: display.daily.ensembleSecondary,
    datePlacePrimary: display.daily.datePlacePrimary,
    datePlaceSecondary: display.daily.datePlaceSecondary,
    href: `/recordings/${recording.id}/`,
    imageSrc: recording.images[0]?.src ?? "",
  };
});

const recentUpdates = buildRecentWorkUpdates(library, 5);
---

<BaseLayout title={`${site.title} | 首页`} description={site.description}>
  <div class="container home-shell">
    <section class="home-intro">
      <h1>{site.title}</h1>
      <p>{site.subtitle}</p>
      <p class="page-note">{site.heroIntro || site.description}</p>
    </section>

    <div class="section-divider"></div>

    <DailyRecommendations items={recommendationItems} />

    <section class="home-updates">
      <div class="section-heading section-heading--centered">
        <p class="section-heading__eyebrow">Recent Changes</p>
        <h2>最近更新</h2>
      </div>

      <div class="line-entry-list">
        {recentUpdates.map((item) => (
          <article class="line-entry">
            <div>
              <h3><a href={item.href}>{item.workTitle}</a></h3>
              <p>{item.composerName}</p>
            </div>
            <span>{item.updatedAt}</span>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
