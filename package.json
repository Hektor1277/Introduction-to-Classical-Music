{
  "name": "introduction-to-classical-music",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:indexes && astro dev --root apps/site --host 127.0.0.1 --port 4321",
    "build": "npm run build:indexes && astro build --root apps/site",
    "preview": "astro preview --root apps/site",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:indexes": "npm run runtime:build && node output/runtime/scripts/build-indexes.js",
    "import:legacy": "npm run runtime:build && node output/runtime/scripts/import-legacy.js",
    "recording:legacy-audit": "npm run runtime:build && node output/runtime/scripts/audit-recording-legacy-alignment.js",
    "recording:live-audit": "npm run runtime:build && node scripts/audit-recording-retrieval-live.mjs",
    "recording:live-verify": "npm run runtime:build && node scripts/verify-recording-retrieval-live-integration.mjs",
    "reference:audit": "npm run runtime:build && node output/runtime/scripts/audit-reference-registry.js",
    "reference:query": "npm run runtime:build && node output/runtime/scripts/query-reference-registry.js",
    "reference:sync": "npm run runtime:build && node output/runtime/scripts/sync-reference-registry.js",
    "owner": "npm run runtime:build && node output/runtime/apps/owner/server/owner-app.js",
    "check": "astro check && vitest run",
    "runtime:build": "tsc -p tsconfig.runtime.json"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "astro": "^5.18.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.2",
    "markdown-it": "^14.1.1",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
